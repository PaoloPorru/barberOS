# ─── SERVER ─────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── DATABASE ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=barberos
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/barberos
# Render/Neon: incolla qui la stringa completa dal provider (obbligatoria in cloud)

# ─── AUTH ────────────────────────────────────────
JWT_SECRET=change-me-to-a-very-long-random-secret-256-bits
JWT_REFRESH_SECRET=another-very-long-random-secret-for-refresh
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── REDIS ───────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Opzionale in cloud: se omesso l’API parte con cache slot in-memory. Produzione: Upstash rediss://…

# ─── EMAIL ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tuamail@gmail.com
SMTP_PASS=tua-app-password
FROM_EMAIL=noreply@barberos.it
FROM_NAME=BarberOS

# ─── APP ─────────────────────────────────────────
# Produzione: URL esatto del browser (Vercel). Più origini: separa con virgola
# (es. https://tuo-app.vercel.app,http://localhost:5173)
FRONTEND_URL=http://localhost:5173
BCRYPT_ROUNDS=12
